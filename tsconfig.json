{
  "compilerOptions": {
    "baseUrl": ".",
    "lib": [
      "DOM",
      "ES2022"
    ],
    "module": "ESNext",
    "target": "ES2022",
    "allowJs": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "moduleResolution": "Bundler",
    "importHelpers": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "importsNotUsedAsValues": "remove",
    "inlineSources": true,
    "sourceMap": true,
    "types": [
      "node",
      "svelte"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.svelte"
  ]
}
